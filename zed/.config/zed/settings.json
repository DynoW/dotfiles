// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "ssh_connections": [
    {
      "host": "home2",
      "args": [],
      "projects": [
        {
          "paths": ["/home/home2"],
        },
      ],
    },
    {
      "host": "zeus",
      "args": [],
      "projects": [
        {
          "paths": ["/home/dyno/Projects"],
        },
      ],
    },
  ],
  "agent_servers": {
    "github-copilot-cli": {
      "favorite_config_option_values": {
        "model": [
          "gpt-5.4-mini",
          "claude-sonnet-4.5"
        ]
      },
      "type": "registry",
    },
    "github-copilot": {
      "type": "registry",
    },
  },
  "agent": {
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "claude-haiku-4.5",
        "enable_thinking": false
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5-mini",
        "enable_thinking": false
      }
    ],
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5",
      "enable_thinking": false
    },
    "dock": "left",
  },
  "edit_predictions": {
    "copilot": {
      "enable_next_edit_suggestions": true
    },
    "provider": "copilot",
  },
  "outline_panel": {
    "dock": "left",
  },
  "icon_theme": "Material Icon Theme",
  "disable_ai": false,
  "project_panel": {
    "dock": "right",
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "JetBrains Light",
    "dark": "JetBrains Dark",
  },
  "vim_mode": true
}
